# NullRecords AI Engine — Environment Variables
# Copy this file to .env and fill in your keys.

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Pexels ---
PEXELS_API_KEY=

# --- Spotify (for playlist discovery) ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- YouTube (for channel discovery) ---
YOUTUBE_API_KEY=

# --- Label ---
LABEL_GENRE=nu jazz, experimental electronic
LABEL_NAME=NullRecords
